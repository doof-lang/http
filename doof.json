{
  "name": "std/http",
  "version": "0.1.0",
  "license": "ISC",
  "externalDependencies": {
    "curl": {
      "kind": "archive",
      "url": "https://curl.se/download/curl-8.20.0.tar.xz",
      "sha256": "63fe2dc148ba0ceae89922ef838f7e5c946272c2e78b7c59fab4b79d3ce2b896",
      "stripComponents": 1,
      "destination": "vendor/curl",
      "commands": [
        {
          "program": "sh",
          "args": [
            "${packageRoot}/build-curl.sh",
            "${destination}",
            "${nativeTarget}",
            "${configureHost}",
            "${targetTriple}",
            "${sdkPath}",
            "${jobs}"
          ]
        }
      ]
    }
  },
  "build": {
    "native": {
      "extraCopyPaths": [
        "native_http_client.hpp",
        "vendor/curl/COPYING",
        "vendor/curl/RELEASE-NOTES"
      ],
      "macos": {
        "sourceFiles": [
          "native_http_client_apple.mm"
        ],
        "frameworks": [
          "Foundation"
        ]
      },
      "iosSimulator": {
        "sourceFiles": [
          "native_http_client_apple.mm"
        ],
        "frameworks": [
          "Foundation"
        ]
      },
      "iosDevice": {
        "sourceFiles": [
          "native_http_client_apple.mm"
        ],
        "frameworks": [
          "Foundation"
        ]
      },
      "linux": {
        "sourceFiles": [
          "native_http_client_curl.cpp"
        ],
        "pkgConfigPackages": [
          "openssl"
        ],
        "includePaths": [
          "vendor/curl/.doof-build/linux/include"
        ],
        "libraryPaths": [
          "vendor/curl/.doof-build/linux/lib"
        ],
        "linkLibraries": [
          "curl"
        ]
      },
      "windows": {
        "sourceFiles": [
          "native_http_client_curl.cpp"
        ],
        "includePaths": [
          "vendor/curl/.doof-build/windows/include"
        ],
        "libraryPaths": [
          "vendor/curl/.doof-build/windows/lib"
        ],
        "linkLibraries": [
          "curl"
        ]
      }
    }
  },
  "dependencies": {}
}
